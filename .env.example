# fleet-memory server config — copy to .env.
#
# DEFAULT: KEYLESS — no API key, fully local. fastembed runs embeddings on-device;
# memories are stored verbatim (add_memory infer is forced off, so no LLM is called).
# Zero-config start. To enable LLM-backed fact extraction + dedup, comment this out,
# pick a provider below, and call add_memory with infer=true.
LLM_PROVIDER=none

# ---- Optional: LLM-backed providers (enable fact extraction + dedup) ----

# Option A: Universal (LiteLLM — any provider, one key, local embeddings)
# Works with OpenAI, Anthropic, OpenRouter, Together, Groq, Mistral, etc.
# Embeddings run locally via fastembed — no second key needed.
# LLM_PROVIDER=litellm
# LLM_API_KEY=<your key>
# MEM0_LLM_MODEL=openai/gpt-4o-mini          # or anthropic/claude-3-5-haiku-20241022
#                                             # or openrouter/anthropic/claude-3-5-haiku

# Bearer auth — set to require Authorization: Bearer <token> on all MCP requests.
# Leave unset (or empty) to allow unauthenticated access (development only).
# MCP_AUTH_TOKEN=

# Option B: OpenAI (native, highest quality embeddings)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# Option B: OpenRouter (any model, OpenAI-compatible)
# Embeddings use Ollama — pull nomic-embed-text first, or drop OLLAMA_URL to use OpenAI embeddings.
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-or-...
# OPENAI_API_BASE=https://openrouter.ai/api/v1
# MEM0_LLM_MODEL=anthropic/claude-3-5-haiku
# OLLAMA_URL=http://host.docker.internal:11434

# Option C: Anthropic (needs separate embedder)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# MEM0_LLM_MODEL=claude-3-5-haiku-20241022
# Embeddings — set one of:
#   OPENAI_API_KEY=sk-...         (OpenAI embeddings)
#   OLLAMA_URL=http://host.docker.internal:11434  (Ollama nomic-embed-text)

# Option D: Ollama (local, free — no API key needed)
# Pull models first: ollama pull qwen3:8b && ollama pull nomic-embed-text
# LLM_PROVIDER=ollama
# OLLAMA_URL=http://host.docker.internal:11434

# Telemetry — both mem0 and Qdrant collect anonymous usage data by default.
# Uncomment to disable.
# MEM0_TELEMETRY=false
# (Qdrant: set QDRANT__TELEMETRY_DISABLED=true in docker-compose.yml under qdrant environment)
