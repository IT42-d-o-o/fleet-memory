# fleet-memory server config — copy to .env and fill in your key.

# Option A: OpenAI (best quality)
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Option B: Ollama (local, free — no API key needed)
# Pull models first: ollama pull qwen3:8b && ollama pull nomic-embed-text
# LLM_PROVIDER=ollama
# OLLAMA_URL=http://host.docker.internal:11434   # Windows/Mac
# OLLAMA_URL=http://host.docker.internal:11434   # Linux (host-gateway wired in compose)
