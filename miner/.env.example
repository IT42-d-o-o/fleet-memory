# Fleet Memory MCP server endpoint
FLEET_MEMORY_URL=http://127.0.0.1:8800/mcp

# Root directory containing your project repos (used by --markdown and --git flags)
# PROJECTS_ROOT=/home/user/projects

# ── Forge credentials (set the ones you use) ───────────────────────────────

# GitHub (--github flag): create at https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_...
# GITHUB_URL=https://api.github.com          # override for GitHub Enterprise

# GitLab (--gitlab flag): create at https://gitlab.com/-/user_settings/personal_access_tokens
# GITLAB_TOKEN=glpat-...
# GITLAB_URL=https://gitlab.com              # override for self-hosted

# Gitea (--gitea flag): token or falls back to git credential store
# GITEA_TOKEN=...
GITEA_URL=http://127.0.0.1:3000

# ── LLM provider (pick one) ────────────────────────────────────────────────

# Ollama (default — no key needed):
# OLLAMA_URL=http://localhost:11434
# LLM_MODEL=qwen3:8b

# Any OpenAI-compatible endpoint (OpenAI, DeepSeek, Kimi, Groq, Together, Gemini):
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=deepseek-chat

# Groq:
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_...
# LLM_MODEL=llama-3.1-70b-versatile

# Anthropic (highest priority if set):
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-haiku-4-5-20251001

# ── Prometheus telemetry (optional) ────────────────────────────────────────
# Leave empty or unset to disable. Set to push token usage to Pushgateway.
# PUSHGATEWAY_URL=http://your-pushgateway:9091
